<Window x:Class="uFPCEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="https://github.com/Dirkster99/AvalonDock"
        xmlns:vm="clr-namespace:uFPCEditor.ViewModels"
        xmlns:views="clr-namespace:uFPCEditor.Views"
        xmlns:debug="clr-namespace:uFPCEditor.Views.Debug"
        xmlns:compiler="clr-namespace:uFPCEditor.Views.Compiler"
        Title="Free Pascal IDE"
        Height="800" Width="1280"
        WindowState="Maximized">

    <Window.DataContext>
        <Binding Path="MainViewModel" Source="{StaticResource ServiceLocator}"/>
    </Window.DataContext>

    <!-- ═══════════════════════════════════════════════ 키보드 단축키 ═══ -->
    <Window.InputBindings>
        <!-- File -->
        <KeyBinding Key="N"   Modifiers="Ctrl"       Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="O"   Modifiers="Ctrl"       Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S"   Modifiers="Ctrl"       Command="{Binding SaveCommand}"/>
        <KeyBinding Key="S"   Modifiers="Ctrl+Shift" Command="{Binding SaveAllCommand}"/>
        <KeyBinding Key="W"   Modifiers="Ctrl"       Command="{Binding CloseCommand}"/>
        <!-- Run / Build -->
        <KeyBinding Key="F9"  Modifiers="Alt"        Command="{Binding CompileCommand}"/>
        <KeyBinding Key="F9"                         Command="{Binding BuildCommand}"/>
        <KeyBinding Key="F9"  Modifiers="Ctrl"       Command="{Binding RunCommand}"/>
        <!-- Debug step (FPC IDE 기본 단축키) -->
        <KeyBinding Key="F8"                         Command="{Binding StepOverCommand}"/>
        <KeyBinding Key="F7"                         Command="{Binding StepIntoCommand}"/>
        <KeyBinding Key="F8"  Modifiers="Shift"      Command="{Binding StepOutCommand}"/>
        <KeyBinding Key="F4"                         Command="{Binding RunToCursorCommand}"/>
        <!-- Debug control -->
        <KeyBinding Key="F5"                         Command="{Binding ToggleBreakpointCommand}"/>
        <KeyBinding Key="F2"                         Command="{Binding ResetDebuggerCommand}"/>
        <KeyBinding Key="F7"  Modifiers="Ctrl"       Command="{Binding AddWatchCommand}"/>
        <KeyBinding Key="F4"  Modifiers="Ctrl"       Command="{Binding EvaluateCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ═══════════════════════════════════════════════════ MENU BAR ═══ -->
        <Menu DockPanel.Dock="Top" Style="{StaticResource FpcMenuStyle}">
            <!-- File -->
            <MenuItem Header="_File">
                <MenuItem Header="_New"           Command="{Binding NewFileCommand}"       InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..."        Command="{Binding OpenFileCommand}"      InputGestureText="Ctrl+O"/>
                <MenuItem Header="Open _Recent"    ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemTemplate>
                        <DataTemplate>
                            <MenuItem Header="{Binding}" Command="{Binding DataContext.OpenRecentCommand,
                                RelativeSource={RelativeSource AncestorType=Menu}}"
                                      CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Save"           Command="{Binding SaveCommand}"          InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..."     Command="{Binding SaveAsCommand}"/>
                <MenuItem Header="Save A_ll"       Command="{Binding SaveAllCommand}"       InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Close"          Command="{Binding CloseCommand}"         InputGestureText="Ctrl+W"/>
                <Separator/>
                <MenuItem Header="E_xit"           Command="{Binding ExitCommand}"          InputGestureText="Alt+F4"/>
            </MenuItem>

            <!-- Edit -->
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"           Command="ApplicationCommands.Undo"       InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo"           Command="ApplicationCommands.Redo"       InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Cu_t"            Command="ApplicationCommands.Cut"        InputGestureText="Ctrl+X"/>
                <MenuItem Header="_Copy"           Command="ApplicationCommands.Copy"       InputGestureText="Ctrl+C"/>
                <MenuItem Header="_Paste"          Command="ApplicationCommands.Paste"      InputGestureText="Ctrl+V"/>
                <MenuItem Header="Select _All"     Command="ApplicationCommands.SelectAll"  InputGestureText="Ctrl+A"/>
                <Separator/>
                <MenuItem Header="_Find..."        Command="{Binding FindCommand}"          InputGestureText="Ctrl+F"/>
                <MenuItem Header="Find _Next"      Command="{Binding FindNextCommand}"      InputGestureText="F3"/>
                <MenuItem Header="Find _Previous"  Command="{Binding FindPrevCommand}"      InputGestureText="Shift+F3"/>
                <MenuItem Header="_Replace..."     Command="{Binding ReplaceCommand}"       InputGestureText="Ctrl+H"/>
                <Separator/>
                <MenuItem Header="Go to _Line..."  Command="{Binding GotoLineCommand}"      InputGestureText="Ctrl+G"/>
            </MenuItem>

            <!-- Search -->
            <MenuItem Header="_Search">
                <MenuItem Header="_Find in Files..." Command="{Binding FindInFilesCommand}" InputGestureText="Ctrl+Shift+F"/>
                <MenuItem Header="_Symbol..."         Command="{Binding FindSymbolCommand}"/>
                <MenuItem Header="_Procedure..."      Command="{Binding FindProcedureCommand}"/>
            </MenuItem>

            <!-- Run -->
            <MenuItem Header="_Run">
                <MenuItem Header="_Compile"        Command="{Binding CompileCommand}"       InputGestureText="Alt+F9"/>
                <MenuItem Header="_Build"          Command="{Binding BuildCommand}"         InputGestureText="F9"/>
                <MenuItem Header="_Make"           Command="{Binding MakeCommand}"/>
                <Separator/>
                <MenuItem Header="_Run"            Command="{Binding RunCommand}"           InputGestureText="Ctrl+F9"/>
                <MenuItem Header="_Parameters..."  Command="{Binding ParametersCommand}"/>
                <Separator/>
                <MenuItem Header="Primary _File..." Command="{Binding BrowsePrimaryFileCommand}"/>
                <MenuItem Header="Clear _Primary"   Command="{Binding ClearPrimaryCommand}"/>
            </MenuItem>

            <!-- Debug -->
            <MenuItem Header="_Debug">
                <MenuItem Header="_Step Over"          Command="{Binding StepOverCommand}"       InputGestureText="F8"/>
                <MenuItem Header="Step _Into"          Command="{Binding StepIntoCommand}"       InputGestureText="F7"/>
                <MenuItem Header="Step _Out"           Command="{Binding StepOutCommand}"        InputGestureText="Shift+F8"/>
                <MenuItem Header="Run to _Cursor"      Command="{Binding RunToCursorCommand}"    InputGestureText="F4"/>
                <Separator/>
                <MenuItem Header="Toggle _Breakpoint"  Command="{Binding ToggleBreakpointCommand}" InputGestureText="F5"/>
                <MenuItem Header="_Show Breakpoints"   Command="{Binding ShowBreakpointsCommand}"/>
                <Separator/>
                <MenuItem Header="Add _Watch..."       Command="{Binding AddWatchCommand}"       InputGestureText="Ctrl+F7"/>
                <MenuItem Header="Show _Watches"       Command="{Binding ShowWatchesCommand}"/>
                <Separator/>
                <MenuItem Header="Show _Call Stack"    Command="{Binding ShowCallStackCommand}"/>
                <MenuItem Header="Show _Registers"     Command="{Binding ShowRegistersCommand}"/>
                <MenuItem Header="Show _Disassembly"   Command="{Binding ShowDisassemblyCommand}"/>
                <Separator/>
                <MenuItem Header="E_valuate..."        Command="{Binding EvaluateCommand}"       InputGestureText="Ctrl+F4"/>
                <Separator/>
                <MenuItem Header="_Reset Debugger"     Command="{Binding ResetDebuggerCommand}"/>
                <MenuItem Header="Open _GDB Console"   Command="{Binding OpenGdbConsoleCommand}"/>
            </MenuItem>

            <!-- Tools -->
            <MenuItem Header="_Tools">
                <MenuItem Header="_Compiler Options..." Command="{Binding CompilerOptionsCommand}"/>
                <MenuItem Header="_Debugger Options..." Command="{Binding DebuggerOptionsCommand}"/>
                <MenuItem Header="_Directories..."      Command="{Binding DirectoriesCommand}"/>
                <Separator/>
                <MenuItem Header="C_alculator"          Command="{Binding CalculatorCommand}"/>
                <MenuItem Header="ASCII _Table"         Command="{Binding AsciiTableCommand}"/>
            </MenuItem>

            <!-- Window -->
            <MenuItem Header="_Window">
                <MenuItem Header="Tile _Horizontal"    Command="{Binding TileHorizontalCommand}"/>
                <MenuItem Header="Tile _Vertical"      Command="{Binding TileVerticalCommand}"/>
                <MenuItem Header="_Cascade"            Command="{Binding CascadeCommand}"/>
                <Separator/>
                <MenuItem Header="Window _List..."     Command="{Binding WindowListCommand}"/>
            </MenuItem>

            <!-- Help -->
            <MenuItem Header="_Help">
                <MenuItem Header="Help _Contents"      Command="{Binding HelpContentsCommand}"   InputGestureText="F1"/>
                <MenuItem Header="_Topic Search"       Command="{Binding HelpTopicCommand}"       InputGestureText="Ctrl+F1"/>
                <Separator/>
                <MenuItem Header="_About..."           Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ══════════════════════════════════════════════════ TOOL BAR ═══ -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Command="{Binding NewFileCommand}"   ToolTip="New (Ctrl+N)"   Content="🗋"/>
                <Button Command="{Binding OpenFileCommand}"  ToolTip="Open (Ctrl+O)"  Content="📂"/>
                <Button Command="{Binding SaveCommand}"      ToolTip="Save (Ctrl+S)"  Content="💾"/>
                <Button Command="{Binding SaveAllCommand}"   ToolTip="Save All"       Content="💾*"/>
                <Separator/>
                <Button Command="ApplicationCommands.Cut"    ToolTip="Cut"   Content="✂"/>
                <Button Command="ApplicationCommands.Copy"   ToolTip="Copy"  Content="⎘"/>
                <Button Command="ApplicationCommands.Paste"  ToolTip="Paste" Content="📋"/>
                <Separator/>
                <Button Command="{Binding CompileCommand}"   ToolTip="Compile (Alt+F9)"    Content="⚙"/>
                <Button Command="{Binding BuildCommand}"     ToolTip="Build (F9)"          Content="🔨"/>
                <Button Command="{Binding RunCommand}"       ToolTip="Run (Ctrl+F9)"       Content="▶"/>
                <Separator/>
                <Button Command="{Binding StepOverCommand}"  ToolTip="Step Over (F8)"      Content="→"/>
                <Button Command="{Binding StepIntoCommand}"  ToolTip="Step Into (F7)"      Content="↓"/>
                <Button Command="{Binding StepOutCommand}"   ToolTip="Step Out (Shift+F8)" Content="↑"/>
                <Separator/>
                <Button Command="{Binding ToggleBreakpointCommand}" ToolTip="Toggle Breakpoint (F5)" Content="🔴"/>
                <Button Command="{Binding ResetDebuggerCommand}"    ToolTip="Reset Debugger"         Content="⏹"/>
            </ToolBar>
        </ToolBarTray>

        <!-- ══════════════════════════════════════════════════ STATUS BAR ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Style="{StaticResource FpcStatusBarStyle}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" MinWidth="200"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveEditor.PositionText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding DebugState}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ══════════════════════════════════════════════ DOCK MANAGER ═══ -->
        <dock:DockingManager x:Name="DockManager"
                             ActiveContent="{Binding ActiveDocument, Mode=TwoWay}"
                             DocumentsSource="{Binding OpenDocuments}">

            <dock:DockingManager.LayoutItemContainerStyle>
                <Style TargetType="{x:Type dock:LayoutItem}">
                    <Setter Property="Title"           Value="{Binding Model.Title}"/>
                    <Setter Property="CloseCommand"    Value="{Binding Model.CloseCommand}"/>
                    <Setter Property="IsSelected"      Value="{Binding Model.IsSelected, Mode=TwoWay}"/>
                    <Setter Property="IsActive"        Value="{Binding Model.IsActive,   Mode=TwoWay}"/>
                </Style>
            </dock:DockingManager.LayoutItemContainerStyle>

            <dock:DockingManager.LayoutItemTemplateSelector>
                <views:PaneTemplateSelector>
                    <views:PaneTemplateSelector.EditorTemplate>
                        <DataTemplate>
                            <views:SourceEditorView/>
                        </DataTemplate>
                    </views:PaneTemplateSelector.EditorTemplate>
                </views:PaneTemplateSelector>
            </dock:DockingManager.LayoutItemTemplateSelector>

            <dock:LayoutRoot>
                <dock:LayoutPanel Orientation="Vertical">

                    <!-- Editor area + left/right panels -->
                    <dock:LayoutPanel Orientation="Horizontal">

                        <!-- Editor documents area (center) -->
                        <dock:LayoutDocumentPaneGroup>
                            <dock:LayoutDocumentPane/>
                        </dock:LayoutDocumentPaneGroup>

                        <!-- Right panel: debug tools -->
                        <dock:LayoutAnchorablePaneGroup DockWidth="300" Orientation="Vertical">
                            <dock:LayoutAnchorablePane>
                                <dock:LayoutAnchorable Title="Breakpoints" ContentId="Breakpoints">
                                    <debug:BreakpointsView DataContext="{Binding BreakpointsViewModel,
                                        Source={StaticResource ServiceLocator}}"/>
                                </dock:LayoutAnchorable>
                                <dock:LayoutAnchorable Title="Watches" ContentId="Watches">
                                    <debug:WatchesView DataContext="{Binding WatchesViewModel,
                                        Source={StaticResource ServiceLocator}}"/>
                                </dock:LayoutAnchorable>
                            </dock:LayoutAnchorablePane>
                            <dock:LayoutAnchorablePane>
                                <dock:LayoutAnchorable Title="Registers" ContentId="Registers">
                                    <debug:RegistersView DataContext="{Binding RegistersViewModel,
                                        Source={StaticResource ServiceLocator}}"/>
                                </dock:LayoutAnchorable>
                            </dock:LayoutAnchorablePane>
                        </dock:LayoutAnchorablePaneGroup>

                    </dock:LayoutPanel>

                    <!-- Bottom panel: output / compiler messages / call stack -->
                    <dock:LayoutAnchorablePaneGroup DockHeight="200" Orientation="Horizontal">
                        <dock:LayoutAnchorablePane>
                            <dock:LayoutAnchorable Title="Compiler Messages" ContentId="CompilerMessages">
                                <compiler:CompilerMessagesView DataContext="{Binding CompilerViewModel,
                                    Source={StaticResource ServiceLocator}}"/>
                            </dock:LayoutAnchorable>
                            <dock:LayoutAnchorable Title="Call Stack" ContentId="CallStack">
                                <debug:CallStackView DataContext="{Binding CallStackViewModel,
                                    Source={StaticResource ServiceLocator}}"/>
                            </dock:LayoutAnchorable>
                            <dock:LayoutAnchorable Title="Output" ContentId="Output">
                                <TextBox x:Name="OutputBox" IsReadOnly="True"
                                         FontFamily="Consolas" FontSize="12"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding OutputText}"/>
                            </dock:LayoutAnchorable>
                        </dock:LayoutAnchorablePane>
                    </dock:LayoutAnchorablePaneGroup>

                </dock:LayoutPanel>
            </dock:LayoutRoot>

        </dock:DockingManager>
    </DockPanel>

</Window>
