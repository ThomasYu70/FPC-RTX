<Window x:Class="uFPCEditor.Views.Debug.EvaluateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Evaluate / Add Watch"
        Width="500" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <!-- 원본 참조: Org/packages/ide/fpevalw.pas  (Tevaluate_dialog) -->

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Expression -->
        <Label Grid.Row="0" Content="_Expression:" Target="{Binding ElementName=ExpressionBox}"/>
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Evaluate"
                    Command="{Binding EvaluateCommand}"
                    Padding="12,4" Margin="4,0,0,0" IsDefault="True"/>
            <TextBox x:Name="ExpressionBox"
                     Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Consolas" FontSize="13"
                     VerticalContentAlignment="Center">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding EvaluateCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
        </DockPanel>

        <!-- Result -->
        <Label Grid.Row="2" Content="_Result:"/>
        <TextBox Grid.Row="3"
                 Text="{Binding ResultText, Mode=OneWay}"
                 IsReadOnly="True"
                 FontFamily="Consolas" FontSize="13"
                 Margin="0,0,0,8"
                 Background="#F5F5F5"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="Add _Watch" Command="{Binding AddWatchCommand}" Padding="10,4" Margin="0,0,6,0"/>
            <Button Content="Close"      IsCancel="True"                     Padding="10,4"
                    Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
