<UserControl x:Class="uFPCEditor.Views.Debug.CallStackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Go to Source" Command="{Binding GoToSourceCommand}" ToolTip="Navigate to source"/>
        </ToolBar>

        <ListView ItemsSource="{Binding CallStack}"
                  SelectedItem="{Binding SelectedFrame, Mode=TwoWay}"
                  FontFamily="Consolas" FontSize="12">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="#"        Width="30"
                                    DisplayMemberBinding="{Binding Level}"/>
                    <GridViewColumn Header="Function" Width="180"
                                    DisplayMemberBinding="{Binding Function}"/>
                    <GridViewColumn Header="File"     Width="140"
                                    DisplayMemberBinding="{Binding ShortFileName}"/>
                    <GridViewColumn Header="Line"     Width="50"
                                    DisplayMemberBinding="{Binding Line}"/>
                    <GridViewColumn Header="Address"  Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Address, StringFormat='0x{0:X8}'}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

            <ListView.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                              Command="{Binding GoToSourceCommand}"/>
            </ListView.InputBindings>
        </ListView>
    </DockPanel>
</UserControl>
