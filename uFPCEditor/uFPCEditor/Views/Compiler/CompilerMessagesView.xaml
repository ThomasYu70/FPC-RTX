<UserControl x:Class="uFPCEditor.Views.Compiler.CompilerMessagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:uFPCEditor.Core.Compiler">

    <DockPanel>
        <!-- 상태 표시줄 -->
        <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" BorderBrush="#CCCCCC" Padding="4,2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0">
                    <Run Text="Errors: "/>
                    <Run Text="{Binding ErrorCount,   Mode=OneWay}" Foreground="Red"/>
                    <Run Text="  Warnings: "/>
                    <Run Text="{Binding WarningCount, Mode=OneWay}" Foreground="DarkOrange"/>
                </TextBlock>
                <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- 툴바 -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Go to Error"  Command="{Binding GoToErrorCommand}"    ToolTip="Navigate to error location"/>
            <Button Content="Clear"        Command="{Binding ClearMessagesCommand}" ToolTip="Clear all messages"/>
        </ToolBar>

        <!-- 메시지 목록 -->
        <ListView ItemsSource="{Binding Messages}"
                  SelectedItem="{Binding SelectedMessage, Mode=TwoWay}"
                  FontFamily="Consolas" FontSize="12"
                  VirtualizingPanel.IsVirtualizing="True"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Kind"     Width="60"
                                    DisplayMemberBinding="{Binding Kind}"/>
                    <GridViewColumn Header="File"     Width="150"
                                    DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="Line"     Width="45"
                                    DisplayMemberBinding="{Binding Line}"/>
                    <GridViewColumn Header="Col"      Width="40"
                                    DisplayMemberBinding="{Binding Column}"/>
                    <GridViewColumn Header="Message"  Width="500"
                                    DisplayMemberBinding="{Binding Text}"/>
                </GridView>
            </ListView.View>

            <!-- 오류/경고 행 색상 -->
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsError}"   Value="True">
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                            <Setter Property="Foreground" Value="DarkOrange"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding GoToErrorCommand}"/>
            </ListView.InputBindings>
        </ListView>
    </DockPanel>
</UserControl>
