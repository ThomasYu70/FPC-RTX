<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- 로컬 패키지 (avalonedit 6.3.0.90 - net9.0 호환) -->
    <add key="local" value="packages" />
    <!-- 공개 NuGet (Dirkster.AvalonDock, CommunityToolkit.Mvvm 등) -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
