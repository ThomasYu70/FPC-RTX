    <Link>
      <SubSystem>Windows</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <GenerateDebugInformation>true</GenerateDebugInformation>
    </Link>
    <PostBuildEvent>
      <!-- ufpcbridge.dll을 출력 디렉토리로 복사 -->
      <Command>xcopy /Y /D "$(MSBuildProjectDirectory)\..\..\uFPC\build\sdk\ufpcbridge.dll" "$(OutDir)"</Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <!-- 헤더 -->
  <ItemGroup>
    <ClInclude Include="pch.h" />
    <ClInclude Include="CompilerBridge.h" />
  </ItemGroup>

  <!-- 소스 파일 (전체 /clr:netcore — pch.h가 #using <System.dll> 포함) -->
  <ItemGroup>
    <ClCompile Include="pch.cpp">
      <PrecompiledHeader>Create</PrecompiledHeader>
    </ClCompile>
    <ClCompile Include="CompilerBridge.cpp" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
